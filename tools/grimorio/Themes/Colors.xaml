<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- VS Code Dark Theme — Brushes directly (no cross-refs) -->
    <SolidColorBrush x:Key="BgDarkestBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="BgDarkBrush" Color="#252526" />
    <SolidColorBrush x:Key="BgMediumBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="BgLightBrush" Color="#333333" />
    <SolidColorBrush x:Key="BgLighterBrush" Color="#3C3C3C" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="#454545" />

    <SolidColorBrush x:Key="FgPrimaryBrush" Color="#CCCCCC" />
    <SolidColorBrush x:Key="FgSecondaryBrush" Color="#858585" />
    <SolidColorBrush x:Key="FgMutedBrush" Color="#6A6A6A" />
    <SolidColorBrush x:Key="FgBrightBrush" Color="#FFFFFF" />

    <SolidColorBrush x:Key="AccentBlueBrush" Color="#007ACC" />
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#1A8AD4" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#4EC9B0" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#CE9178" />
    <SolidColorBrush x:Key="AccentYellowBrush" Color="#DCDCAA" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#F44747" />
    <SolidColorBrush x:Key="AccentTealBrush" Color="#2AA198" />

    <SolidColorBrush x:Key="BorderBrush" Color="#3C3C3C" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#454545" />

    <SolidColorBrush x:Key="SelectionBrush" Color="#264F78" />
    <SolidColorBrush x:Key="LineHighlightBrush" Color="#2A2D2E" />

    <SolidColorBrush x:Key="ScrollbarBgBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#424242" />
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="#4F4F4F" />

    <SolidColorBrush x:Key="StatusRunningBrush" Color="#4EC9B0" />
    <SolidColorBrush x:Key="StatusStoppedBrush" Color="#F44747" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#DCDCAA" />
</ResourceDictionary>
