<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MCR.Grimorio.Controls">
    <Style TargetType="local:NavButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:NavButton">
                    <Border Name="Border" Background="{TemplateBinding Background}"
                            BorderThickness="0" Padding="12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Name="IconText" Text="{TemplateBinding Icon}" FontSize="14"
                                       Width="24" TextAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="{TemplateBinding Label}" FontSize="13"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{StaticResource BgHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{StaticResource BgLighterBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
