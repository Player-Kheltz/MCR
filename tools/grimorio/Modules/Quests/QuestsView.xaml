<UserControl x:Class="MCR.Grimorio.Modules.Quests.QuestsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkestBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="📋 Quest Designer Rico (SQH)" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" />
                <TextBlock Text="8 tipos de missão · Parâmetros dinâmicos · Recompensas · Cores MCR" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Panel 1: Basic Info -->
            <Border Grid.Row="1" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="Nome da Quest" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                        <TextBox x:Name="QuestNameBox" Text="Nova Missão" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0">
                        <TextBlock Text="NPC" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                        <TextBox x:Name="QuestNpcBox" Text="MestreNPC" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="6,0">
                        <TextBlock Text="Storage ID" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                        <TextBox x:Name="QuestStorageBox" Text="50000" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="6,0,0,0">
                        <TextBlock Text="Nível Mínimo" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                        <TextBox x:Name="QuestLevelBox" Text="1" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel 2: Quest Type + Parameters -->
            <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Tipo de Missão" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="QuestTypeBox" Margin="0,2,0,0" SelectedIndex="0" SelectionChanged="QuestTypeBox_SelectionChanged">
                                <ComboBoxItem Content="Matar (Kill)" />
                                <ComboBoxItem Content="Coletar (Collect)" />
                                <ComboBoxItem Content="Entregar (Deliver)" />
                                <ComboBoxItem Content="Explorar (Explore)" />
                                <ComboBoxItem Content="Falar (Talk)" />
                                <ComboBoxItem Content="Escoltar (Escort)" />
                                <ComboBoxItem Content="Craft (Craft)" />
                                <ComboBoxItem Content="Tempo (Timed)" />
                            </ComboBox>
                        </StackPanel>
                        <Border Grid.Column="1" x:Name="TypeParamsPanel" Background="{StaticResource BgDarkBrush}" CornerRadius="4" Padding="10">
                            <Grid x:Name="TypeParamsGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- Dynamically managed -->
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- NPC Dialog Lines -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Fala de Oferta" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="OfferText" Height="40" AcceptsReturn="True" TextWrapping="Wrap" FontSize="10"
                                     Text="Preciso de sua ajuda, aventureiro! Aceita?" Margin="0,2,0,0"
                                     Background="{StaticResource BgDarkestBrush}" Foreground="{StaticResource FgPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0">
                            <TextBlock Text="Fala de Progresso" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="ProgressText" Height="40" AcceptsReturn="True" TextWrapping="Wrap" FontSize="10"
                                     Text="Já conseguiu o que pedi?" Margin="0,2,0,0"
                                     Background="{StaticResource BgDarkestBrush}" Foreground="{StaticResource FgPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0,0,0">
                            <TextBlock Text="Fala de Conclusão" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="CompleteText" Height="40" AcceptsReturn="True" TextWrapping="Wrap" FontSize="10"
                                     Text="Excelente trabalho! Aqui está sua recompensa." Margin="0,2,0,0"
                                     Background="{StaticResource BgDarkestBrush}" Foreground="{StaticResource FgPrimaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Panel 3: Rewards -->
            <Border Grid.Row="3" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Recompensas" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" Margin="0,0,0,6" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="XP" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="RewardXpBox" Text="500" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0">
                            <TextBlock Text="Moedas (Gold)" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="RewardMoneyBox" Text="200" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0">
                            <TextBlock Text="Item ID (1º)" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="RewardItemIdBox" Text="3725" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="6,0">
                            <TextBlock Text="Qtd Item" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="RewardItemQtyBox" Text="5" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Margin="6,0,0,0">
                            <TextBlock Text="Domínio (Afinidade)" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="RewardDomainBox" Margin="0,2,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Nenhum" />
                                <ComboBoxItem Content="Fogo (23)" />
                                <ComboBoxItem Content="Gelo (24)" />
                                <ComboBoxItem Content="Terra (25)" />
                                <ComboBoxItem Content="Energia (26)" />
                                <ComboBoxItem Content="Espadas Leves (100)" />
                                <ComboBoxItem Content="Espadas Pesadas (101)" />
                                <ComboBoxItem Content="Combate (1)" />
                                <ComboBoxItem Content="Magia (2)" />
                                <ComboBoxItem Content="Lâminas (10)" />
                                <ComboBoxItem Content="Elementos (20)" />
                                <ComboBoxItem Content="Summon (28)" />
                                <ComboBoxItem Content="Sobrevivência (400)" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Panel 4: Domain Requirement -->
            <Border Grid.Row="4" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Requisito de Domínio (opcional)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" Margin="0,0,0,6" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Domínio" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="ReqDomainBox" Margin="0,2,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Nenhum" />
                                <ComboBoxItem Content="Fogo (23)" />
                                <ComboBoxItem Content="Gelo (24)" />
                                <ComboBoxItem Content="Terra (25)" />
                                <ComboBoxItem Content="Energia (26)" />
                                <ComboBoxItem Content="Espadas Leves (100)" />
                                <ComboBoxItem Content="Espadas Pesadas (101)" />
                                <ComboBoxItem Content="Combate (1)" />
                                <ComboBoxItem Content="Magia (2)" />
                                <ComboBoxItem Content="Lâminas (10)" />
                                <ComboBoxItem Content="Elementos (20)" />
                                <ComboBoxItem Content="Summon (28)" />
                                <ComboBoxItem Content="Sobrevivência (400)" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Nível Mínimo no Domínio" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="ReqDomainLevelBox" Text="5" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Output & Actions -->
            <Grid Grid.Row="5" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Código Gerado (SQH):" FontSize="11" Foreground="{StaticResource FgMutedBrush}" Margin="0,0,0,4" />
                <TextBox Grid.Row="1" x:Name="QuestOutput" IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                         Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource FgPrimaryBrush}"
                         BorderThickness="0" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         MinHeight="150" MaxHeight="400" />
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                    <Button x:Name="GenerateQuestButton" Content="▶ Gerar SQH" Style="{StaticResource PrimaryButton}" Height="30" Width="120" Click="GenerateQuestButton_Click" />
                    <Button x:Name="CopyQuestBtn" Content="📋 Copiar" Height="30" Width="100" Margin="6,0,0,0" Click="CopyQuestBtn_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
