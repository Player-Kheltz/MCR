<UserControl x:Class="MCR.Grimorio.Modules.Npcs.NpcsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkestBrush}">

    <Grid Margin="8,4,8,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="4,0,4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="NPCs" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrightBrush}" />
            <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                       FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                       Margin="12,4,0,0" />
            <Button Grid.Column="2" Command="{Binding GerarMcrCommand}"
                    Content="✨ Gerar via MCR"
                    FontSize="11" FontWeight="SemiBold" Padding="10,4"
                    Margin="0,0,6,0"
                    Background="{StaticResource AccentGreenBrush}"
                    Foreground="Black" Cursor="Hand"
                    ToolTip="Gera um novo NPC usando o motor MCR" />
            <Button Grid.Column="3" Command="{Binding RefreshListCommand}"
                    Content="⟳" FontSize="11" Padding="6,2" />
        </Grid>

        <!-- Body: Lista (esq) + Editor (dir) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Coluna Esquerda: Lista de NPCs -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}"
                            Padding="8,5" CornerRadius="4,4,0,0">
                        <TextBlock Text="NPCs do Mundo" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>
                    <TextBox Grid.Row="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filtrar NPCs" Padding="4,2" Margin="4"
                             FontSize="11" />
                    <ListView Grid.Row="2" ItemsSource="{Binding FilteredNpcs}"
                              Background="Transparent" BorderThickness="0"
                              SelectedItem="{Binding SelectedNpc, Mode=TwoWay}"
                              SelectionChanged="NpcList_SelectionChanged"
                              VirtualizingPanel.ScrollUnit="Pixel">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12"
                                           Foreground="{StaticResource FgPrimaryBrush}"
                                           Padding="6,4" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BgDarkestBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Coluna Direita: Editor com pestanas -->
            <Border Grid.Column="2"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="0">
                <TabControl Background="Transparent" BorderThickness="0"
                            Padding="4">
                    <TabItem Header="Config" FontSize="11"
                             Background="{StaticResource BgDarkBrush}"
                             Foreground="{StaticResource FgPrimaryBrush}">
                        <Grid Margin="6" Grid.IsSharedSizeScope="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" SharedSizeGroup="Label" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:"
                                       FontSize="12" Foreground="{StaticResource FgSecondaryBrush}"
                                       Margin="0,4,8,4" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding NpcName}" FontSize="12" Padding="4,2" Margin="0,4" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Descrição:"
                                       FontSize="12" Foreground="{StaticResource FgSecondaryBrush}"
                                       Margin="0,4,8,4" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding NpcDescription}" FontSize="12" Padding="4,2" Margin="0,4" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Vida:"
                                       FontSize="12" Foreground="{StaticResource FgSecondaryBrush}"
                                       Margin="0,4,8,4" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding NpcHealth}" FontSize="12" Padding="4,2" Margin="0,4" Width="100" HorizontalAlignment="Left" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="LookType:"
                                       FontSize="12" Foreground="{StaticResource FgSecondaryBrush}"
                                       Margin="0,4,8,4" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding NpcLookType}" FontSize="12" Padding="4,2" Margin="0,4" Width="100" HorizontalAlignment="Left" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Diálogo" FontSize="11"
                             Background="{StaticResource BgDarkBrush}"
                             Foreground="{StaticResource FgPrimaryBrush}">
                        <TextBox Text="{Binding DialogText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="11" FontFamily="Consolas"
                                 Padding="4" Margin="4"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#1A1A1A" Foreground="#D4D4D4"
                                 BorderThickness="0" />
                    </TabItem>

                    <TabItem Header="Preview Lua" FontSize="11"
                             Background="{StaticResource BgDarkBrush}"
                             Foreground="{StaticResource FgPrimaryBrush}">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Text="{Binding LuaPreview}"
                                     FontSize="11" FontFamily="Consolas"
                                     Padding="4"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#1A1A1A" Foreground="#D4D4D4"
                                     BorderThickness="0" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button Command="{Binding SalvarCommand}"
                                        Content="💾 Salvar no Servidor"
                                        FontSize="11" Padding="8,3"
                                        Background="{StaticResource AccentGreenBrush}"
                                        Foreground="Black" Cursor="Hand" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
