<UserControl x:Class="MCR.Grimorio.Modules.Logs.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkestBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Logs" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" />
            <TextBlock Text="Visualizador de logs do servidor" FontSize="13" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,4,0,0" />
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,8,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Filtros" FontSize="12" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,0,0,8" />
                    <Button x:Name="ShowAllButton" Content="Todos" Height="30" Margin="0,0,0,4" Click="ShowAllButton_Click" />
                    <Button x:Name="ShowErrorsButton" Content="Erros" Height="30" Margin="0,0,0,4" Click="ShowErrorsButton_Click" />
                    <Button x:Name="ShowWarningsButton" Content="Warnings" Height="30" Margin="0,0,0,4" Click="ShowWarningsButton_Click" />
                    <Separator Background="{StaticResource BorderBrush}" Margin="0,8" />
                    <Button x:Name="RefreshLogsButton" Content="⟳ Atualizar" Height="30" Click="RefreshLogsButton_Click" />
                    <Button x:Name="ClearLogsButton" Content="Limpar" Height="30" Margin="0,4,0,0" Click="ClearLogsButton_Click" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource BgDarkBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="LogContent" IsReadOnly="True" FontFamily="Consolas" FontSize="11" Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource FgPrimaryBrush}" BorderThickness="0" VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
