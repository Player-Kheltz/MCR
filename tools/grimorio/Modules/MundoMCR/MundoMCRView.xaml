<UserControl x:Class="MCR.Grimorio.Modules.MundoMCR.MundoMCRView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BgDarkestBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🌍 Mundo MCR" FontSize="24"
                       FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Painel de Observação do Organismo"
                           FontSize="13" Foreground="{StaticResource FgSecondaryBrush}"
                           Margin="0,4,0,0" />
                <Ellipse x:Name="ConnectionIndicator" Width="10" Height="10"
                         Fill="{StaticResource StatusStoppedBrush}"
                         Margin="12,8,6,0" />
                <TextBlock x:Name="ConnectionText" Text="{Binding StatusConexao}"
                           FontSize="12" Foreground="{StaticResource FgMutedBrush}"
                           Margin="0,6,0,0" />
                <Button Command="{Binding RefreshCommand}"
                        Content="⟳ Atualizar" FontSize="11" Padding="8,2"
                        Margin="12,0,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Content Grid: 2 rows x 2 cols -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ ZONA 1: Telemetria Vital (topo, ocupa 2 colunas) ═══ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Entropia -->
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="ENTROPIA" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                        <TextBlock Text="{Binding Entropia, StringFormat={}{0:F2}}" FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Margin="0,4,0,2" />
                        <Border Background="#333" CornerRadius="4" Height="8"
                                Margin="0,0,8,0">
                            <Border x:Name="EntropiaBar" Width="{Binding EntropiaBarWidth}"
                                    Background="{StaticResource AccentGreenBrush}"
                                    CornerRadius="4" HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Text="{Binding UltimaAcao, StringFormat='Última ação: {0}'}"
                                   FontSize="10" Foreground="{StaticResource FgMutedBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- NPCs -->
                    <StackPanel Grid.Column="1" Margin="8,0">
                        <TextBlock Text="NPCs" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                        <TextBlock Text="{Binding NpcsDisplay}" FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgBrightBrush}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding NpcsVivos, StringFormat='Vivos: {0}'}"
                                   FontSize="12" Foreground="{StaticResource AccentGreenBrush}" />
                        <TextBlock Text="{Binding NpcsMortos, StringFormat='Mortos: {0}'}"
                                   FontSize="12" Foreground="#F44747" />
                    </StackPanel>

                    <!-- Monstros -->
                    <StackPanel Grid.Column="2" Margin="8,0">
                        <TextBlock Text="MONSTROS" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                        <TextBlock Text="{Binding TotalMonstros}" FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentOrangeBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Quests -->
                    <StackPanel Grid.Column="3" Margin="8,0">
                        <TextBlock Text="QUESTS" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                        <TextBlock Text="{Binding TotalQuests}" FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentGreenBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Threshold -->
                    <StackPanel Grid.Column="4" Margin="8,0,0,0">
                        <TextBlock Text="THRESHOLD METACOG" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                        <TextBlock Text="{Binding ThresholdMetacog, StringFormat={}{0:P0}}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource FgBrightBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ ZONA 2: Eventos Reais (esquerda) ═══ -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Margin="0,0,6,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}"
                            Padding="12,8" CornerRadius="6,6,0,0">
                        <TextBlock Text="📡 EVENTOS DO SERVIDOR" FontSize="12"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="Transparent" Padding="4">
                        <ItemsControl ItemsSource="{Binding Eventos}"
                                      Background="Transparent">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1" Padding="8,6"
                                            ToolTip="{Binding Details}"
                                            Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="6" Height="6"
                                                     Fill="{StaticResource AccentGreenBrush}"
                                                     Margin="0,4,8,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Display}"
                                                       FontSize="12" FontFamily="Consolas"
                                                       Foreground="{StaticResource FgPrimaryBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{StaticResource BgDarkBrush}"
                            Padding="8,6" CornerRadius="0,0,6,6">
                        <TextBlock Text="Passe o mouse para detalhes" FontSize="10"
                                   Foreground="{StaticResource FgMutedBrush}" />
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ ZONA 3+4: Decisoes + Perturbacao (direita) ═══ -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ZONA 3: Log de Decisões -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Margin="6,0,0,6" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{StaticResource BgLightBrush}"
                                Padding="12,8" CornerRadius="6,6,0,0">
                            <TextBlock Text="🧠 DECISÕES MCR" FontSize="12"
                                       Foreground="{StaticResource FgSecondaryBrush}" />
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      Background="Transparent" Padding="4">
                            <ItemsControl ItemsSource="{Binding Decisoes}"
                                          Background="Transparent">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,6"
                                                Background="Transparent">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="#FFA500"
                                                             Margin="0,4,8,0" />
                                                    <TextBlock Text="{Binding Display}"
                                                               FontSize="12"
                                                               FontFamily="Consolas"
                                                               Foreground="{StaticResource FgPrimaryBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ZONA 4: Painel de Perturbação -->
                <Border Grid.Row="1"
                        Background="{StaticResource BgMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Margin="6,0,0,0" Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="⚠ SIMULAR PERTURBAÇÃO"
                                   FontSize="12"
                                   Foreground="{StaticResource FgSecondaryBrush}"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0" Width="90"
                                      Text="{Binding PerturbType}"
                                      SelectedItem="{Binding PerturbType}"
                                      Margin="0,0,6,0" FontSize="12">
                                <ComboBoxItem Content="death" IsSelected="True" />
                                <ComboBoxItem Content="kill" />
                                <ComboBoxItem Content="spawn" />
                                <ComboBoxItem Content="login" />
                            </ComboBox>

                            <TextBox Grid.Column="1"
                                     Text="{Binding PerturbTarget}"
                                     ToolTip="Nome do alvo"
                                     Margin="0,0,6,0" Padding="4,2"
                                     FontSize="12" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding PerturbKiller}"
                                     ToolTip="Nome do assassino"
                                     Margin="0,0,6,0" Padding="4,2"
                                     FontSize="12" />

                            <Button Grid.Column="3"
                                    Command="{Binding PerturbarCommand}"
                                    Content="▶ DISPARAR"
                                    FontSize="11" FontWeight="SemiBold"
                                    Padding="10,4"
                                    Background="{StaticResource AccentGreenBrush}"
                                    Foreground="Black" Cursor="Hand" />
                        </Grid>

                        <TextBlock Text="{Binding ResultadoPerturb}"
                                   FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}"
                                   Margin="0,4,0,0" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
