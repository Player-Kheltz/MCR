<UserControl x:Class="MCR.Grimorio.Modules.PainelMCR.PainelMCRView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BgDarkestBrush}">

    <Grid Margin="8,4,8,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER: titulo + botao testes ═══ -->
        <Grid Grid.Row="0" Margin="4,0,4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Painel de Controle MCR"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrightBrush}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="TestToggleBtn" Content="🧪 Testes"
                        FontSize="11" Padding="8,2" Cursor="Hand"
                        Click="ToggleTestPanel" />
                <Button Command="{Binding RefreshCommand}"
                        Content="⟳" FontSize="11" Padding="6,2"
                        Margin="6,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- ═══ STATUS CARDS: compactos, densos ═══ -->
        <Grid Grid.Row="1" Margin="4,0,4,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="0,0,3,0" Padding="10,6">
                <StackPanel>
                    <TextBlock Text="SERVIDOR" FontSize="10"
                               Foreground="{StaticResource FgSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource StatusStoppedBrush}"
                                 Margin="0,5,6,0" />
                        <TextBlock Text="{Binding ServerStatusText}" FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FgBrightBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="3,0" Padding="10,6">
                <StackPanel>
                    <TextBlock Text="ENTROPIA" FontSize="10"
                               Foreground="{StaticResource FgSecondaryBrush}" />
                    <TextBlock Text="—" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="3,0" Padding="10,6">
                <StackPanel>
                    <TextBlock Text="NPCs" FontSize="10"
                               Foreground="{StaticResource FgSecondaryBrush}" />
                    <TextBlock Text="—" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Margin="3,0,0,0" Padding="10,6">
                <StackPanel>
                    <TextBlock Text="EVENTOS" FontSize="10"
                               Foreground="{StaticResource FgSecondaryBrush}" />
                    <TextBlock Text="{Binding Eventos.Count}" FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ PAINEIS PRINCIPAIS: log + eventos ═══ -->
        <Grid Grid.Row="2" Margin="4,0,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Log do servidor -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}"
                            Padding="8,5" CornerRadius="4,4,0,0">
                        <TextBlock Text="📋 Log do Servidor" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="Transparent" Padding="6">
                        <TextBlock Text="Log do servidor — disponível na próxima fase"
                                   Foreground="{StaticResource FgMutedBrush}"
                                   FontSize="11" FontStyle="Italic" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BgDarkestBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Eventos do mundo -->
            <Border Grid.Column="2"
                    Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}"
                            Padding="8,5" CornerRadius="4,4,0,0">
                        <TextBlock Text="📡 Eventos do Mundo" FontSize="11"
                                   Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="Transparent" Padding="2">
                        <ItemsControl ItemsSource="{Binding Eventos}"
                                      Background="Transparent">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,4" Background="Transparent">
                                        <TextBlock FontSize="11" FontFamily="Consolas"
                                                   Foreground="{StaticResource FgPrimaryBrush}">
                                            <Run Text="{Binding Timestamp, StringFormat={}{0}}" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Type}" FontWeight="Bold" />
                                            <Run Text="  " />
                                            <Run Text="{Binding Target}" />
                                            <Run Text=" → " />
                                            <Run Text="{Binding Killer}" Foreground="{StaticResource AccentOrangeBrush}" />
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ EXPANDER: Testes / Perturbacao (recolhido por padrao) ═══ -->
        <Expander Grid.Row="3" x:Name="TestExpander"
                  Header="🧪 Ferramentas de Teste"
                  IsExpanded="False"
                  Margin="4,4,4,0" Padding="8,4"
                  Background="{StaticResource BgMediumBrush}"
                  Foreground="{StaticResource FgSecondaryBrush}"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  FontSize="11">
            <Grid Margin="4,6,4,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Simular perturbação no mundo MCR"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource FgSecondaryBrush}"
                           Margin="0,0,0,6" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" Width="80"
                              Text="{Binding PerturbType}"
                              Margin="0,0,4,0" FontSize="11">
                        <ComboBoxItem Content="death" IsSelected="True" />
                        <ComboBoxItem Content="kill" />
                        <ComboBoxItem Content="spawn" />
                    </ComboBox>

                    <TextBox Grid.Column="1" Text="{Binding PerturbTarget}"
                             ToolTip="Nome do alvo" Padding="2,1"
                             Margin="0,0,4,0" FontSize="11" />

                    <TextBox Grid.Column="2" Text="{Binding PerturbKiller}"
                             ToolTip="Nome do assassino" Padding="2,1"
                             Margin="0,0,4,0" FontSize="11" />

                    <Button Grid.Column="3"
                            Command="{Binding PerturbarCommand}"
                            Content="▶ Disparar"
                            FontSize="11" Padding="8,2"
                            Background="{StaticResource AccentGreenBrush}"
                            Foreground="Black" Cursor="Hand" />
                </Grid>

                <TextBlock Grid.Row="2" Text="{Binding ResultadoPerturb}"
                           FontSize="10"
                           Foreground="{StaticResource FgMutedBrush}"
                           Margin="0,4,0,0" />
            </Grid>
        </Expander>
    </Grid>
</UserControl>
