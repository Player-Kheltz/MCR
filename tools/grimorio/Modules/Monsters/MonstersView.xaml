<UserControl x:Class="MCR.Grimorio.Modules.Monsters.MonstersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkestBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="👾" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Monstros" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" />
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" />
                </StackPanel>
                <TextBox Grid.Column="2" x:Name="SearchBox" Width="220" Padding="8,5" FontSize="12"
                         TextChanged="SearchBox_TextChanged" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Categories -->
            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}" Padding="10,7" CornerRadius="6,6,0,0">
                        <TextBlock Text="Categorias" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>
                    <ListBox Grid.Row="1" x:Name="CategoryList" Background="Transparent" BorderThickness="0"
                             SelectionChanged="CategoryList_SelectionChanged" FontSize="12" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="{StaticResource BgDarkestBrush}"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Monster List -->
            <Border Grid.Column="2" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}" Padding="10,7" CornerRadius="6,6,0,0">
                        <TextBlock x:Name="ListTitle" Text="Selecione uma categoria" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>
                    <ListView Grid.Row="1" x:Name="MonsterList" Background="Transparent" BorderThickness="0"
                              SelectionChanged="MonsterList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="40" Margin="2,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource BgDarkBrush}" CornerRadius="4" Width="28" Height="28">
                                        <Image Source="{Binding Sprite}" Width="28" Height="28" SnapsToDevicePixels="True" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0" FontSize="12" />
                                    <TextBlock Grid.Column="2" Text="{Binding Exp, StringFormat='EXP {0:N0}'}" Foreground="{StaticResource AccentOrangeBrush}" VerticalAlignment="Center" FontSize="11" />
                                    <TextBlock Grid.Column="3" Text="{Binding Hp, StringFormat='HP {0:N0}'}" Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center" FontSize="11" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" Background="{StaticResource BgDarkestBrush}"
                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="0"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Detail Panel -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="14">
                    <StackPanel x:Name="DetailPanel">
                        <!-- Sprite + Name -->
                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="8" Height="80" Margin="0,0,0,10">
                            <Grid>
                                <Image x:Name="DetailSprite" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                                <TextBlock x:Name="DetailName" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4" />
                            </Grid>
                        </Border>

                        <TextBlock x:Name="DetailDesc" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap" />

                        <!-- Stats -->
                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"><TextBlock Text="HP" FontSize="10" Foreground="{StaticResource FgMutedBrush}" /><TextBlock x:Name="DHP" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" /></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Text="EXP" FontSize="10" Foreground="{StaticResource FgMutedBrush}" /><TextBlock x:Name="DExp" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" /></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Speed" FontSize="10" Foreground="{StaticResource FgMutedBrush}" /><TextBlock x:Name="DSpeed" FontSize="16" Foreground="{StaticResource AccentTealBrush}" /></StackPanel>
                            </Grid>
                        </Border>

                        <!-- Combat Stats -->
                        <Border Background="{StaticResource BgDarkBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"><TextBlock Text="Armor" FontSize="10" Foreground="{StaticResource FgMutedBrush}" /><TextBlock x:Name="DArmor" FontSize="14" /></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Text="Defense" FontSize="10" Foreground="{StaticResource FgMutedBrush}" /><TextBlock x:Name="DDefense" FontSize="14" /></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Mana Cost" FontSize="10" Foreground="{StaticResource FgMutedBrush}" /><TextBlock x:Name="DMana" FontSize="14" /></StackPanel>
                            </Grid>
                        </Border>

                        <!-- Loot -->
                        <TextBlock Text="Loot" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" Margin="0,0,0,4" />
                        <ListView x:Name="LootList" Background="{StaticResource BgDarkBrush}" BorderThickness="0" Height="100" Margin="0,0,0,10">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Id}" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11" />
                                        <TextBlock Grid.Column="2" Text="{Binding ChancePct, StringFormat='{}{0:F1}%'}" FontSize="11" Foreground="{StaticResource AccentGreenBrush}" />
                                        <TextBlock Grid.Column="3" Text="{Binding MaxCount}" FontSize="11" Foreground="{StaticResource AccentOrangeBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Attacks -->
                        <TextBlock Text="Ataques" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" Margin="0,0,0,4" />
                        <ListView x:Name="AttackList" Background="{StaticResource BgDarkBrush}" BorderThickness="0" Height="80" Margin="0,0,0,10">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11" />
                                        <TextBlock Grid.Column="1" Text="{Binding Damage}" FontSize="11" Foreground="{StaticResource AccentRedBrush}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Interval}" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Elements -->
                        <TextBlock Text="Elementos" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" Margin="0,0,0,4" />
                        <ItemsControl x:Name="ElementsPanel" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,3" Margin="2,2"
                                            Background="{Binding Bg}" BorderThickness="0">
                                        <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{Binding Fg}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
