<UserControl x:Class="MCR.Grimorio.Modules.Config.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkestBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚙️" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Configuração" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" />
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" />
                </StackPanel>
                <TextBox Grid.Column="2" x:Name="SearchBox" Padding="8,5" FontSize="12" TextChanged="SearchBox_TextChanged" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}" Padding="10,7" CornerRadius="6,6,0,0">
                        <TextBlock Text="Config Keys" FontSize="11" Foreground="{StaticResource FgSecondaryBrush}" />
                    </Border>
                    <ListView Grid.Row="1" x:Name="ConfigList" Background="Transparent" BorderThickness="0"
                              SelectionChanged="ConfigList_SelectionChanged"
                              DisplayMemberPath="Key" FontSize="12" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="{StaticResource BgDarkestBrush}"
                          BorderBrush="{StaticResource BorderBrush}" ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2" Background="{StaticResource BgMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                    Padding="16" Visibility="Collapsed" x:Name="DetailPanel">
                <StackPanel>
                    <TextBlock x:Name="DetailKey" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentOrangeBrush}" />

                    <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4" Padding="8,3" Margin="0,6,0,8" HorizontalAlignment="Left">
                        <TextBlock x:Name="DetailType" FontSize="11" Foreground="{StaticResource AccentTealBrush}" />
                    </Border>

                    <TextBlock Text="Valor" FontSize="11" Foreground="{StaticResource FgMutedBrush}" Margin="0,0,0,3" />
                    <TextBox x:Name="ValueBox" Padding="8,6" FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap" MaxHeight="120" />

                    <TextBlock Text="Descrição" FontSize="11" Foreground="{StaticResource FgMutedBrush}" Margin="0,0,0,3" />
                    <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4" Padding="10,8" MinHeight="40" Margin="0,0,0,12">
                        <TextBlock x:Name="DetailDesc" FontSize="12" Foreground="{StaticResource FgSecondaryBrush}" TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="SaveButton" Content="Salvar" Style="{StaticResource PrimaryButton}" Height="34" Width="100"
                                IsEnabled="False" Click="SaveButton_Click" Margin="0,0,0,0" />
                    </StackPanel>

                    <TextBlock x:Name="SaveStatus" FontSize="11" Margin="0,6,0,0" Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
