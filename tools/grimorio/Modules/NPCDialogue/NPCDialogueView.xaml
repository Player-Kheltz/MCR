<UserControl x:Class="MCR.Grimorio.Modules.NPCDialogue.NPCDialogueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDarkestBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="💬 NPC Dialogue Rico (MCR)" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource FgBrightBrush}" />
                    <TextBlock x:Name="DetectionText" FontSize="11" Foreground="{StaticResource AccentGreenBrush}" />
                </StackPanel>
            </Border>

            <!-- Config Panel -->
            <Border Grid.Row="1" Background="{StaticResource BgMediumBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: Basic Info -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Nome do NPC" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="NpcNameBox" Text="NovoNPC" Margin="0,2,0,6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0">
                            <TextBlock Text="Personalidade" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="PersonalityBox" Margin="0,2,0,6" SelectedIndex="0">
                                <ComboBoxItem Content="Amigável" />
                                <ComboBoxItem Content="Sábio" />
                                <ComboBoxItem Content="Misterioso" />
                                <ComboBoxItem Content="Rude" />
                                <ComboBoxItem Content="Alegre" />
                                <ComboBoxItem Content="Guerreiro" />
                                <ComboBoxItem Content="Místico" />
                                <ComboBoxItem Content="Comerciante" />
                                <ComboBoxItem Content="Ferreiro" />
                                <ComboBoxItem Content="Herbalista" />
                                <ComboBoxItem Content="Arcanista" />
                                <ComboBoxItem Content="Eremita" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0,0,0">
                            <TextBlock Text="Outfit (lookType)" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="OutfitBox" Text="130" Margin="0,2,0,6" />
                        </StackPanel>
                        <Button Grid.Column="3" x:Name="GenerateButton" Content="▶ Gerar" Style="{StaticResource PrimaryButton}" Height="30" Width="80" Margin="8,0,0,0" Click="GenerateButton_Click" />
                    </Grid>

                    <!-- Row 1: Schedule + Gender -->
                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="Turno (Schedule)" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="ScheduleBox" Margin="0,2,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Nenhum" />
                                <ComboBoxItem Content="Dia/Noite" />
                                <ComboBoxItem Content="Manhã/Tarde/Noite" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0">
                            <TextBlock Text="Domínio para Reagir" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="DomainBox" Margin="0,2,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Nenhum" />
                                <ComboBoxItem Content="Fogo (23)" />
                                <ComboBoxItem Content="Gelo (24)" />
                                <ComboBoxItem Content="Terra (25)" />
                                <ComboBoxItem Content="Energia (26)" />
                                <ComboBoxItem Content="Espadas Leves (100)" />
                                <ComboBoxItem Content="Espadas Pesadas (101)" />
                                <ComboBoxItem Content="Machados (11)" />
                                <ComboBoxItem Content="Combate (1)" />
                                <ComboBoxItem Content="Magia (2)" />
                                <ComboBoxItem Content="Lâminas (10)" />
                                <ComboBoxItem Content="Summon (28)" />
                                <ComboBoxItem Content="Sobrevivência (400)" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0">
                            <TextBlock Text="Tipo de Diálogo" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <ComboBox x:Name="DialogTypeBox" Margin="0,2,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="Básico (saudações)" />
                                <ComboBoxItem Content="Com Shop" />
                                <ComboBoxItem Content="Com Quest" />
                                <ComboBoxItem Content="Completo (Shop + Quest)" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="6,0,0,0">
                            <TextBlock Text="Descrição" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox x:Name="DescBox" Text="Um NPC amigável." Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- Row 2: Shop Items (conditionally visible) -->
                    <Border Grid.Row="2" x:Name="ShopPanel" Background="{StaticResource BgDarkBrush}" CornerRadius="4" Padding="10" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Itens da Loja (um por linha: nome,clientId,precoCompra,precoVenda)" FontSize="11" Foreground="{StaticResource FgMutedBrush}" />
                            <TextBox Grid.Row="1" x:Name="ShopItemsBox" Height="60" FontFamily="Consolas" FontSize="10"
                                     AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,4"
                                     Background="{StaticResource BgDarkestBrush}" Foreground="{StaticResource FgPrimaryBrush}"
                                     BorderThickness="0" VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Output -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Código Gerado:" FontSize="11" Foreground="{StaticResource FgMutedBrush}" Margin="0,0,0,4" />
                <TextBox Grid.Row="1" x:Name="OutputBox" IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                         Background="{StaticResource BgDarkBrush}" Foreground="{StaticResource FgPrimaryBrush}"
                         BorderThickness="0" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         MinHeight="200" MaxHeight="500" />
            </Grid>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="CopyButton" Content="📋 Copiar" Height="30" Width="100" Margin="0,0,6,0" Click="CopyButton_Click" />
                <Button x:Name="SaveFileButton" Content="💾 Salvar (.lua)" Height="30" Width="120" Click="SaveFileButton_Click" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
