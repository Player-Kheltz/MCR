class MCR:
    """Cadeia de Markov universal  BIGRAM."""
    def __init__(self, nome: str = ""):
        self.nome = nome
        self.transicoes: Dict[str, Dict[str, int]] = {}
        self.freq: Dict[str, int] = {}
        self.total: int = 0

    def aprender(self, a: str, b: str):
        a, b = str(a), str(b)
        if a not in self.transicoes:
            self.transicoes[a] = {}
            self.freq[a] = 0
        self.transicoes[a][b] = self.transicoes[a].get(b, 0) + 1
        self.freq[a] += 1
        self.total += 1

    def aprender_sequencia(self, seq: List[str]):
        for i in range(len(seq) - 1):
            self.aprender(seq[i], seq[i + 1])

    def predizer(self, a: str) -> Tuple[Optional[str], float]:
        a = str(a)
        if a not in self.transicoes or not self.transicoes[a]:
            return (None, 0.0)
        melhor = max(self.transicoes[a], key=self.transicoes[a].get)
        conf = self.transicoes[a][melhor] / self.freq[a]
        return (melhor, conf)

    def predizer_n(self, a: str, n: int = 3) -> List[Tuple[str, float]]:
        a = str(a)
        if a not in self.transicoes: return []
        ordenados = sorted(self.transicoes[a].items(), key=lambda x: -x[1])
        total = self.freq[a]
        return [(tOK, cnt / total) for tOK, cnt in ordenados[:n]]

    def gerar(self, semente: str, passos: int = 10) -> List[str]:
        seq, atual = [semente], semente
        for _ in range(passos):
            prox, conf = self.predizer(atual)
            if prox is None or conf < 0.01: break
            seq.append(prox); atual = prox
        return seq

    def entropia(self, a: str) -> float:
        a = str(a)
        if a not in self.transicoes or not self.transicoes[a]: return 1.0
        total = self.freq[a]
        return -sum((c / total) * math.log2(c / total) for c in self.transicoes[a].values())

    def entropia_media(self) -> float:
        if not self.freq: return 1.0
        return sum(self.entropia(e) for e in self.freq) / len(self.freq)

    def jaccard(self, outra: 'MCR') -> float:
        ea, eb = set(self.freq.keys()), set(outra.freq.keys())
        if not ea or not eb: return 0.0
        return len(ea & eb) / len(ea | eb)

    def stats(self) -> Dict:
        return {'nome': self.nome, 'estados': len(self.freq),
                'transicoes': sum(len(t) for t in self.transicoes.values()),
                'total': self.total, 'entropia': round(self.entropia_media(), 3)}

    def __repr__(self):
        s = self.stats()
        return f"MCR[{self.nome}]: {s['estados']} estados, H={s['entropia']}"


class MCRByteUtils:
    @staticmethod
    def entropia_bytes(dados, max_bytes=500) -> float:
        if isinstance(dados, str): dados = dados.encode('utf-8')[:max_bytes]
        else: dados = bytes(dados)[:max_bytes]
        if len(dados) < 2: return 0.0
        freq = Counter(dados); n = len(dados)
        return -sum((c/n)*math.log2(c/n) for c in freq.values())

    @staticmethod
    def jaccard_bytes(texto_a: str, texto_b: str) -> float:
        def _trans(s):
            d = s.encode('utf-8')[:500]
            return {f"{d[i]:02x}{d[i+1]:02x}" for i in range(len(d)-1)}
        ta, tb = _trans(texto_a), _trans(texto_b)
        if not ta or not tb: return 0.0
        return len(ta & tb) / len(ta | tb)

    @staticmethod
    def fingerprint(texto: str, dims: int = 8) -> List[float]:
        dados = texto.encode('utf-8')[:500]
        if not dados: return [0.0] * dims
        buckets = [0.0] * dims
        for i, b in enumerate(dados):
            buckets[(i + b) % dims] += 1.0
        total = sum(buckets) or 1
        return [round(b / total * 10, 3) for b in buckets]

    @staticmethod
    def similaridade_cosseno(fp_a: List[float], fp_b: List[float]) -> float:
        if len(fp_a) != len(fp_b):
            m = min(len(fp_a), len(fp_b))
            fp_a, fp_b = fp_a[:m], fp_b[:m]
        if not fp_a: return 0.0
        dot = sum(a*b for a,b in zip(fp_a, fp_b))
        na = math.sqrt(sum(a*a for a in fp_a))
        nb = math.sqrt(sum(b*b for b in fp_b))
        if na == 0 or nb == 0: return 0.0
        return dot / (na * nb)

    @staticmethod
    def delta_fingerprint(a: str, b: str, dim: int = 8) -> List[float]:
        fa = MCRByteUtils.fingerprint(a, dim)
        fb = MCRByteUtils.fingerprint(b, dim)
        return [fb[i] - fa[i] for i in range(dim)]


class MCRSignatureExpansiva:
    @staticmethod
    def fingerprint(dados: bytes, n_dims: int) -> List[float]:
        if not dados: return [0.0] * n_dims
        buckets = [0.0] * n_dims
        for i, b in enumerate(dados):
            buckets[(i + b) % n_dims] += 1.0
        total = sum(buckets) or 1
        return [round(b / total * 10, 3) for b in buckets]

    @staticmethod
    def fingerprint_texto(texto: str, n_dims: int) -> List[float]:
        return MCRSignatureExpansiva.fingerprint(texto.encode('utf-8')[:2000], n_dims)

    @staticmethod
    def similaridade(fp_a: List[float], fp_b: List[float]) -> float:
        return MCRByteUtils.similaridade_cosseno(fp_a, fp_b)

    @staticmethod
    def dimensionalidade_ideal(dados, max_dims=64, threshold=0.05) -> int:
        if isinstance(dados, str): dados = dados.encode('utf-8')[:2000]
        entropias = []
        for dims in [1, 2, 4, 8, 16, 32, 64, 128]:
            if dims > max_dims: break
            fp = MCRSignatureExpansiva.fingerprint(dados, dims)
            total = sum(fp) or 1
            probs = [v/total for v in fp if v > 0]
            h = -sum(p*math.log2(p) for p in probs) if probs else 0
            entropias.append((dims, h))
        for i in range(1, len(entropias)):
            dim_ant, h_ant = entropias[i-1]
            dim_at, h_at = entropias[i]
            if abs(h_at - h_ant) / max(h_ant, 0.01) < threshold:
                return dim_at
        return entropias[-1][0] if entropias else 8


class MCRThreshold:
    """Threshold adaptativo por mediana."""
    def __init__(self, nome: str = "threshold"):
        self.observacoes: List[float] = []
        self.mk = MCR(nome)

    def observar(self, valor: float):
        self.observacoes.append(valor)
        self.mk.aprender(f"VAL:{int(valor*100)}", "OBS")

    def calcular(self, multiplicador: float = 1.0) -> float:
        if len(self.observacoes) < 3: return 0.5
        return median(self.observacoes) * multiplicador

    def aprender(self, chave: str, valor: float):
        self.mk.aprender(f"THR:{chave}", f"{int(valor*100)}")
        self.observar(valor)

    def obter(self, chave: str, fallback: float = 0.5) -> float:
        pred = self.mk.predizer(f"THR:{chave}")
        if pred[0] and pred[1] > 0.3:
            try: return int(pred[0]) / 100.0
            except: pass
        return self.calcular() if len(self.observacoes) >= 3 else fallback


class MCREntropia:
    """Detector de loops por entropia."""
    def __init__(self, nome: str = "entropia"):
        self.mk = MCR(nome)
        self.historico: List[float] = []
        self.threshold = MCRThreshold(f"loop_{nome}")

    def alimentar(self, tven: str):
        self.mk.aprender(f"T:{str(tven)[:50]}", "V")
        h = self.mk.entropia(f"T:{str(tven)[:50]}")
        self.historico.append(h)
        if len(self.historico) > 100: self.historico = self.historico[-50:]

    def esta_em_loop(self) -> bool:
        if len(self.historico) < 3: return False
        h_local = sum(self.historico[-10:]) / min(10, len(self.historico))
        self.threshold.observar(h_local)
        return h_local < self.threshold.calcular(0.5)


