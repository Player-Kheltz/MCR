# SEO 5  MCRSelfModify: Auto-Modificao de Cdigo
# 

class MCRSelfModify:
    """Auto-modificao: detecta hardcodes no prprio cdigo e corrige.

    Usa a Equao MCR (assinatura, entropia) para encontrar linhas
    que DESVIAM da assinatura mdia do arquivo, e sugere/substitui
    valores fixos por chamadas adaptativas.
    """
    def __init__(self, caminho: str = None):
        self.caminho = caminho or os.path.abspath(__file__)
        self.backup_path = self.caminho + ".bak"
        self.historico: List[Dict] = []
        self.total_modificacoes = 0

    def escanear(self) -> List[Dict]:
        """Escaneia o prprio cdigo atrs de hardcodes."""
        with open(self.caminho, 'r', encoding='utf-8') as f:
            linhas = f.readlines()

        linhas_codigo = []
        for i, l in enumerate(linhas):
            s = l.strip()
            if not s or s.startswith('#') or s.startswith('"""') or s.startswith("'''"): continue
            if s.startswith('import ') or s.startswith('from '): continue
            linhas_codigo.append((i + 1, s))

        if not linhas_codigo: return []

        codigo_completo = '\n'.join(l for _, l in linhas_codigo)
        dados_completos = codigo_completo.encode('utf-8')
        fp_medio = MCRSignatureExpansiva.fingerprint(dados_completos, 16)
        h_medio = MCRByteUtils.entropia_bytes(dados_completos)

        # Padres suspeitos de hardcode
        padroes_hardcode = [
            r'\bif\s+[a-z_]+\s*[=!]=\s*["\']',   # if x == "literal"
            r'\breturn\s+(True|False)\b',           # return True/False
            r'(passos|max_iter|threshold|limite|dim|max_candidatos)\s*=\s*\d+',  # parametro fixo
            r'range\(\s*\d+\s*\)',                   # range(10)
        ]

        suspeitos = []
        for num, linha in linhas_codigo:
            dados_linha = linha.encode('utf-8')
            if len(dados_linha) < 10: continue

            h_linha = MCRByteUtils.entropia_bytes(dados_linha)
            fp_linha = MCRSignatureExpansiva.fingerprint(dados_linha, 16)

            dist_fp = 1.0 - MCRSignatureExpansiva.similaridade(fp_linha, fp_medio)
            dist_h = abs(h_linha - h_medio) / max(h_medio, 0.01)
            score = (dist_fp * 0.6 + dist_h * 0.4)

            # Verifica padres
            for padrao in padroes_hardcode:
                if re.search(padrao, linha):
                    score = min(1.0, score + 0.3)
                    break

            if score > 0.5:
                suspeitos.append({
                    "linha": num,
                    "codigo": linha.strip()[:80],
                    "score": round(score, 3),
                    "entropia": round(h_linha, 3),
                })

        suspeitos.sort(key=lambda x: -x["score"])
        return suspeitos

    def substituir_hardcode(self, linha_num: int, codigo_atual: str,
                            nova_variavel: str, contexto: str = "MCRDecisorUniversal") -> bool:
        """Substitui um valor fixo por chamada adaptativa."""
        with open(self.caminho, 'r', encoding='utf-8') as f:
            conteudo = f.read()
        linhas = conteudo.split('\n')

        if linha_num < 1 or linha_num > len(linhas):
            return False

        linha = linhas[linha_num - 1]

        # Detecta o valor fixo na linha
        match = re.search(r'(passos|max_iter|threshold|limite|dim|max_candidatos|conf_min|max_passos)\s*=\s*(\d+)', linha)
        if not match:
            return False

        param_name = match.group(1)
        valor_fixo = match.group(2)

        # Cria substituio
        substituto = f'{param_name} = {contexto}.decidir(motor).get("{param_name}", {valor_fixo})'
        nova_linha = linha.replace(match.group(0), substituto)

        # Faz backup antes
        if not os.path.exists(self.backup_path):
            import shutil
            shutil.copy2(self.caminho, self.backup_path)

        linhas[linha_num - 1] = nova_linha
        with open(self.caminho, 'w', encoding='utf-8') as f:
            f.write('\n'.join(linhas))

        self.total_modificacoes += 1
        self.historico.append({
            "tipo": "hardcode_substituido",
            "linha": linha_num,
            "antes": linha.strip()[:60],
            "depois": nova_linha.strip()[:60],
        })
        return True

    def evoluir_arquitetura(self, bateria_testes=None) -> Dict:
        """Testa N variaes de arquitetura e escolhe a melhor."""
        # L o cdigo atual
        with open(self.caminho, 'r', encoding='utf-8') as f:
            codigo_atual = f.read()

        variaveis = {
            "dim_fp": [4, 8, 16],
            "max_passos": [5, 10, 20],
            "threshold_deteccao": [0.3, 0.5, 0.7],
        }

        resultados = []
        for var_nome, valores in variaveis.items():
            for val in valores:
                # Cria variao
                variacao = re.sub(
                    rf'{var_nome}\s*=\s*\d+',
                    f'{var_nome} = {val}',
                    codigo_atual
                )
                # Salva temporariamente
                temp_path = self.caminho + ".temp"
                with open(temp_path, 'w', encoding='utf-8') as f:
                    f.write(variacao)

                # Testa (se houver bateria de testes)
                fitness = 0.0
                if bateria_testes:
                    fitness = bateria_testes(variacao)

                resultados.append({
                    "variavel": var_nome,
                    "valor": val,
                    "fitness": fitness,
                })

                os.remove(temp_path)

        if not resultados: return {"alterado": False}

        resultados.sort(key=lambda x: -x["fitness"])
        melhor = resultados[0]

        if melhor["fitness"] > 0:
            # Aplica melhor variao
            codigo_novo = re.sub(
                rf'{melhor["variavel"]}\s*=\s*\d+',
                f'{melhor["variavel"]} = {melhor["valor"]}',
                codigo_atual
            )
            with open(self.caminho, 'w', encoding='utf-8') as f:
                f.write(codigo_novo)

            return {
                "alterado": True,
                "variavel": melhor["variavel"],
                "novo_valor": melhor["valor"],
                "fitness": round(melhor["fitness"], 4),
            }

        return {"alterado": False}

    def rolar_backup(self) -> bool:
        """Restaura do backup."""
        if not os.path.exists(self.backup_path): return False
        import shutil
        shutil.copy2(self.backup_path, self.caminho)
        return True

    def stats(self) -> Dict:
        return {
            "total_hardcodes_encontrados": len(self.escanear()),
            "total_modificacoes": self.total_modificacoes,
            "historico": self.historico[-5:] if self.historico else [],
        }

    def __repr__(self):
        s = self.stats()
        return f"MCRSelfModify: {s['total_hardcodes_encontrados']} hardcodes, {s['total_modificacoes']} modificaes"


