class MCRCoupling:
    """Matriz de acoplamento entre nveis de Markov.

    Cada par (nvel_origem, nvel_destino) tem um peso que representa
    o quanto o nvel_origem influencia o nvel_destino.

    Os pesos EMERGEM dos dados: se transies no nvel X
    consistentemente precedem transies no nvel Y, o acoplamento XY
     alto.
    """
    def __init__(self):
        self.niveis = ["byte", "palavra", "tven", "intencao", "acao"]
        self.matriz: Dict[str, Dict[str, float]] = {
            o: {d: 0.0 for d in self.niveis} for o in self.niveis
        }
        # Matriz de contagem de co-ocorrncias
        self.coocorrencias: Dict[str, Dict[str, int]] = {
            o: {d: 0 for d in self.niveis} for o in self.niveis
        }
        self.total_coocorrencias = 0
        self.mk = MCR("coupling")

    def alimentar_transicao(self, nivel_origem: str, nivel_destino: str,
                            tven_origem: str, tven_destino: str):
        """Registra co-ocorrncia de transies entre nveis."""
        if nivel_origem not in self.niveis or nivel_destino not in self.niveis:
            return
        self.coocorrencias[nivel_origem][nivel_destino] += 1
        self.total_coocorrencias += 1
        self.mk.aprender(
            f"CP:{nivel_origem}->{nivel_destino}:{tven_origem[:10]}",
            tven_destino[:10]
        )

    def recalcular_pesos(self):
        """Recalcula a matriz de acoplamento baseada nas co-ocorrncias.
        Usa entropia condicional: H(destino | origem) vs H(destino).

        Peso alto = origem reduz a incerteza sobre destino.
        """
        for origem in self.niveis:
            for destino in self.niveis:
                if origem == destino:
                    self.matriz[origem][destino] = 1.0
                    continue
                count = self.coocorrencias[origem][destino]
                if count < 3 or self.total_coocorrencias == 0:
                    self.matriz[origem][destino] = 0.0
                    continue
                # Peso = freq relativa normalizada
                self.matriz[origem][destino] = round(
                    count / self.total_coocorrencias * len(self.niveis), 3)

    def peso(self, origem: str, destino: str) -> float:
        return self.matriz.get(origem, {}).get(destino, 0.0)

    def modular(self, nivel: str, prob_base: Dict[str, float]) -> Dict[str, float]:
        """Modula probabilidades de um nvel baseado nos acoplamentos.

        Se nvel_palavra tem acoplamento forte com nvel_byte,
        e o byte atual  'X', a probabilidade de palavras que
        co-ocorrem com 'X' aumenta.
        """
        resultado = dict(prob_base)
        for outro_nivel in self.niveis:
            if outro_nivel == nivel: continue
            p = self.peso(outro_nivel, nivel)
            if p > 0.1:
                # Aplica modulao
                for chave in resultado:
                    resultado[chave] = resultado[chave] * (1 + p * 0.1)
        return resultado

    def descobrir_niveis_necessarios(self, motor) -> List[str]:
        """Usa MCRSignatureExpansiva para descobrir quantos nveis
        so realmente necessrios."""
        if not motor.topicos:
            return self.niveis[:2]

        texto_exemplo = list(motor.topicos.values())[0].get("texto", "")
        if not texto_exemplo:
            return self.niveis[:2]

        dim = MCRSignatureExpansiva.dimensionalidade_ideal(
            texto_exemplo.encode("utf-8")[:1000], max_dims=32)

        # Se dim  baixa, poucos nveis so necessrios
        niveis_necessarios = max(2, min(len(self.niveis), dim))
        return self.niveis[:niveis_necessarios]

    def stats(self) -> Dict:
        return {
            "total_coocorrencias": self.total_coocorrencias,
            "niveis_ativos": len(self.niveis),
            "acoplamento_medio": round(
                sum(self.matriz[o][d] for o in self.niveis for d in self.niveis if o != d)
                / max(len(self.niveis) * (len(self.niveis) - 1), 1), 3),
        }

    def __repr__(self):
        s = self.stats()
        linhas = [f"MCRCoupling: {s['niveis_ativos']} nveis, acoplamento mdio={s['acoplamento_medio']}"]
        for o in self.niveis:
            pesos = [f"{d}:{self.matriz[o][d]:.2f}" for d in self.niveis if o != d and self.matriz[o][d] > 0]
            if pesos:
                linhas.append(f"  {o} -> {', '.join(pesos)}")
        return "\n".join(linhas)


