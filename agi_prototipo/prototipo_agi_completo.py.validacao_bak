# SEO 4  MCRPlanner: Planejamento Hierrquico
# 

class MCRPlanner:
    """Planejador hierrquico que decompe objetivos em aes.

    Fluxo:
      1. Calcula delta_fingerprint(estado_atual, estado_objetivo)
      2. Decompe delta grande em sub-deltas
      3. Para cada sub-delta, encontra ao causal
      4. Concatena aes em plano
      5. Avalia e refina
    """
    def __init__(self, world: MCRWorld):
        self.world = world
        self.mk_plano = MCR("planner")
        self.mk_subobjetivo = MCR("planner_sub")
        self.historico_planos: List[Dict] = []
        self.fragmentador = None  # Placeholder para MCRFragmentador

    def plano(self, estado_atual: EstadoMundo, estado_objetivo: EstadoMundo,
              max_passos: int = 10) -> List[str]:
        """Gera plano de aes para ir de estado_atual a estado_objetivo."""
        distancia = self.world.distancia(estado_atual, estado_objetivo)

        # Se j est perto, tenta ao direta
        if distancia < 1.0:
            acao = self.world.predizer_acao(estado_atual, estado_objetivo)
            return [acao] if acao else []

        # Busca plano conhecido por similaridade
        fp_alvo = str(estado_objetivo.fingerprint(self.world.dim_fp))
        plano_conhecido, conf = self.mk_plano.predizer(fp_alvo)
        if plano_conhecido and conf > 0.2:
            acoes = plano_conhecido.split("|")
            if len(acoes) <= max_passos:
                return acoes

        # Decomposio hierrquica
        delta_total = MCRByteUtils.delta_fingerprint(
            estado_atual.serializar(), estado_objetivo.serializar(),
            self.world.dim_fp)

        # Descobre quantos sub-passos so necessrios
        dim_delta = MCRSignatureExpansiva.dimensionalidade_ideal(
            str(delta_total).encode(), max_dims=16)
        num_sub_passos = max(2, min(max_passos, dim_delta))

        sub_deltas = self._decompor_delta(delta_total, num_sub_passos)
        plano_final = []
        estado_intermediario = estado_atual.clone()

        for i, sub_delta in enumerate(sub_deltas):
            # Encontra ao que produz este sub-delta
            sub_delta_str = str(tuple(round(d, 3) for d in sub_delta))

            # Tenta por Markov causal
            acao, conf = self.world.mk_causal.predizer(sub_delta_str)
            if not acao or conf < 0.1:
                # Tenta por sub-objetivo conhecido
                acao_sub, conf_sub = self.mk_subobjetivo.predizer(sub_delta_str)
                acao = acao_sub or self._acao_fallback(estado_intermediario, sub_delta)

            if acao:
                plano_final.append(acao)
                # Simula efeito da ao
                prox_estado = self.world.simular(estado_intermediario, acao)
                if prox_estado:
                    estado_intermediario = prox_estado

        if plano_final:
            self._aprender_plano(plano_final, estado_atual, estado_objetivo)

        return plano_final

    def _decompor_delta(self, delta_total: List[float], n: int) -> List[List[float]]:
        """Decompe delta total em n sub-deltas aproximadamente iguais."""
        if n <= 1: return [delta_total]
        sub_deltas = []
        for i in range(n):
            frac = (i + 1) / n
            frac_ant = i / n
            sub = [(d * frac) - (d * frac_ant) for d in delta_total]
            sub_deltas.append(sub)
        return sub_deltas

    def _acao_fallback(self, estado: EstadoMundo, sub_delta: List[float]) -> str:
        """Fallback: escolhe ao que mais se aproxima do delta desejado."""
        melhor_acao = "andar_cima"
        melhor_score = 0.0

        for acao in ACOES_DISPONIVEIS:
            prox = self.world.fisica.executar(estado, acao)
            delta_acao = MCRByteUtils.delta_fingerprint(
                estado.serializar(), prox.serializar(), self.world.dim_fp)
            score = MCRByteUtils.similaridade_cosseno(delta_acao, sub_delta)
            if score > melhor_score:
                melhor_score = score
                melhor_acao = acao

        return melhor_acao

    def _aprender_plano(self, plano: List[str], estado_inicial: EstadoMundo,
                        estado_final: EstadoMundo):
        """Aprende que este plano funciona para este objetivo."""
        fp_alvo = str(estado_final.fingerprint(self.world.dim_fp))
        self.mk_plano.aprender(fp_alvo, "|".join(plano))

        # Aprende sub-objetivos
        estado_int = estado_inicial.clone()
        for acao in plano:
            prox = self.world.fisica.executar(estado_int, acao)
            delta = tuple(round(d, 3) for d in MCRByteUtils.delta_fingerprint(
                estado_int.serializar(), prox.serializar(), self.world.dim_fp))
            self.mk_subobjetivo.aprender(str(delta), acao)
            estado_int = prox

        self.historico_planos.append({
            "plano": plano,
            "inicial": estado_inicial.serializar()[:30],
            "final": estado_final.serializar()[:30],
            "passos": len(plano),
        })

    def avaliar_plano(self, plano: List[str], estado_inicial: EstadoMundo,
                      estado_esperado: EstadoMundo) -> float:
        """Avalia um plano simulando-o e comparando com o esperado."""
        estado_sim = estado_inicial.clone()
        for acao in plano:
            estado_sim = self.world.fisica.executar(estado_sim, acao)

        sim = MCRByteUtils.similaridade_cosseno(
            estado_sim.fingerprint(self.world.dim_fp),
            estado_esperado.fingerprint(self.world.dim_fp))
        return sim * 10  # nota 0-10

    def stats(self) -> Dict:
        return {
            "planos_aprendidos": self.mk_plano.total,
            "sub_objetivos_aprendidos": self.mk_subobjetivo.total,
            "planos_histrico": len(self.historico_planos),
        }

    def __repr__(self):
        s = self.stats()
        return f"MCRPlanner: {s['planos_aprendidos']} planos, {s['sub_objetivos_aprendidos']} sub-objetivos"


