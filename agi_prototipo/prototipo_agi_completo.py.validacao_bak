# SEO 6  CREBRO AGI (Integrao de TUDO)
# 

class CerebroAGI:
    """Crebro AGI que integra TODOS os modulos do sistema MCR.

    Modulos:
      - World: modelo causal (MCRWorld)
      - Coupling: acoplamento multinivel (MCRCoupling)
      - Planner: planejamento hierarquico (MCRPlanner)
      - SelfModify: auto-modificacao (MCRSelfModify)
      - Memoria: persistencia SQLite (prototipo_mcr_hq.MCRMemory)
      - RL: aprendizado por reforco (prototipo_mcr_rl.MCRRL)
      - Bridge: generalizacao cross-domain (prototipo_mcr_bridge.MCRBridge)
      - Genesis: auto-expansao (prototipo_mcr_genesis.MCRGenesis)
    """
    def __init__(self):
        self.mk_byte = MCR("byte_global")
        self.mk_palavra = MCR("palavra_global")
        self.mk_tven = MCR("tven_global")
        self.topicos: Dict[str, Dict] = {}

        # Modulos AGI base
        self.world = MCRWorld()
        self.coupling = MCRCoupling()
        self.planner = MCRPlanner(self.world)
        self.self_modify = MCRSelfModify()

        # Modulos avancados (importacao tardia)
        self._memoria = None
        self._rl = None
        self._bridge = None
        self._genesis = None
        self._mind = None

        # Meta-estado
        self.total_ciclos = 0
        self.historico_aprendizado: List[Dict] = []
        self.threshold = MCRThreshold("cerebro")
        self.entropia = MCREntropia("cerebro")

    @property
    def memoria(self):
        if self._memoria is None:
            from prototipo_mcr_hq import MCRMemory
            self._memoria = MCRMemory()
        return self._memoria

    @property
    def rl(self):
        if self._rl is None:
            from prototipo_mcr_rl import MCRRL
            self._rl = MCRRL()
        return self._rl

    @property
    def bridge(self):
        if self._bridge is None:
            from prototipo_mcr_bridge import MCRBridge
            self._bridge = MCRBridge()
        return self._bridge

    @property
    def genesis(self):
        if self._genesis is None:
            from prototipo_mcr_genesis import MCRGenesis
            self._genesis = MCRGenesis(self)
        return self._genesis

    @property
    def mind(self):
        if self._mind is None:
            from prototipo_mcr_mind import MCRMind
            self._mind = MCRMind()
        return self._mind

    #  ALIMENTAO DE CONHECIMENTO 

    def alimentar(self, texto: str, nome_topico: str = None) -> str:
        """Alimenta texto no crebro em mltiplos nveis."""
        if nome_topico is None:
            nome_topico = f"topico_{len(self.topicos) + 1}"

        dados = texto.encode('utf-8')
        palavras = texto.split()

        # Nvel byte
        for i in range(len(dados) - 1):
            self.mk_byte.aprender(f"B:{dados[i]:02x}", f"B:{dados[i+1]:02x}")

        # Nvel palavra
        for i in range(len(palavras) - 1):
            self.mk_palavra.aprender(palavras[i], palavras[i + 1])

        # Nvel tven (primeira letra)
        for i in range(len(palavras) - 1):
            ta = palavras[i][0].upper() if palavras[i] else '?'
            tb = palavras[i + 1][0].upper() if palavras[i + 1] else '?'
            self.mk_tven.aprender(ta, tb)

        # Acoplamento: alimenta correlaes entre nveis
        for i in range(min(len(dados) - 1, len(palavras))):
            if i < len(dados) - 1:
                byte_t = f"B:{dados[i]:02x}"
                pal_t = palavras[min(i, len(palavras)-1)]
                tv_t = pal_t[0].upper() if pal_t else '?'
                self.coupling.alimentar_transicao("byte", "palavra", byte_t, pal_t)
                self.coupling.alimentar_transicao("palavra", "tven", pal_t, tv_t)
                self.coupling.alimentar_transicao("tven", "byte", tv_t, byte_t)

        self.topicos[nome_topico] = {
            'texto': texto, 'bytes': len(dados), 'n_palavras': len(palavras),
            'conteudo': {p.lower() for p in palavras if len(p) >= 2},
        }

        self.coupling.recalcular_pesos()
        return nome_topico

    #  APRENDIZADO CAUSAL (World) 

    def aprender_causal(self, antes: EstadoMundo, acao: str, depois: EstadoMundo):
        """Aprende causalidade e tambm alimenta o coupling."""
        self.world.aprender(antes, acao, depois)

        # Alimenta o coupling com a transio causal
        fp_antes = antes.fingerprint(self.world.dim_fp)
        fp_depois = depois.fingerprint(self.world.dim_fp)
        self.coupling.alimentar_transicao(
            "intencao", "acao", str(fp_antes[:3]), acao)
        self.coupling.alimentar_transicao(
            "acao", "intencao", acao, str(fp_depois[:3]))
        self.coupling.recalcular_pesos()

    def simular(self, estado: EstadoMundo, acao: str) -> Optional[EstadoMundo]:
        """Simula com modulao do coupling."""
        resultado = self.world.simular(estado, acao)
        self.entropia.alimentar(f"{estado.serializar()[:20]}:{acao}")
        return resultado

    #  PLANEJAMENTO 

    def planejar(self, objetivo_desc: str, estado_atual: EstadoMundo = None) -> Dict:
        """Gera plano para atingir um objetivo descrito em texto."""
        if estado_atual is None:
            estado_atual = EstadoMundo.criar_simples()

        # Tenta encontrar estado objetivo nos tpicos
        estado_objetivo = self._estado_de_texto(objetivo_desc, estado_atual)
        if not estado_objetivo:
            return {"plano": [], "erro": "objetivo no compreendido"}

        acoes = self.planner.plano(estado_atual, estado_objetivo)

        nota = 0.0
        if acoes:
            nota = self.planner.avaliar_plano(acoes, estado_atual, estado_objetivo)

        return {
            "plano": acoes,
            "passos": len(acoes),
            "nota": round(nota, 2),
            "objetivo": objetivo_desc,
            "estado_inicial": estado_atual.serializar()[:40],
            "estado_objetivo": estado_objetivo.serializar()[:40],
        }

    def _estado_de_texto(self, descricao: str, ref: EstadoMundo) -> Optional[EstadoMundo]:
        """Converte descrio textual em estado objetivo."""
        e = ref.clone()
        desc = descricao.lower()

        if "bau" in desc and "aberto" in desc:
            bau = e.get("bau")
            if bau: bau.props["aberto"] = True
        if "monstro" in desc and ("morto" in desc or "derrotado" in desc):
            e.remover("monstro")
        if "pedra" in desc and ("empurrada" in desc or "movida" in desc):
            pedra = e.get("pedra")
            if pedra: pedra.props["x"] = 3
        if "heroi" in desc:
            m = re.search(r'heroi.*?(\d+).*?(\d+)', desc)
            if m:
                e.entidades["heroi"].props["x"] = int(m.group(1))
                e.entidades["heroi"].props["y"] = int(m.group(2))

        return e

    #  GERAO POR ASSINATURA 

    def gerar(self, texto: str, passos: int = 10) -> str:
        """Gera texto continuando a sequncia, com modulao do coupling."""
        palavras = texto.split()
        if not palavras: return texto

        for _ in range(passos):
            semente = palavras[-1]
            if semente not in self.mk_palavra.freq:
                if len(palavras) > 1:
                    semente = palavras[-2]
                else: break

            candidatos = self.mk_palavra.predizer_n(semente, 5)

            # Modula candidatos com coupling
            if candidatos:
                probs = {c: conf for c, conf in candidatos}
                probs_moduladas = self.coupling.modular("palavra", probs)
                melhor = max(probs_moduladas, key=probs_moduladas.get)
                palavras.append(melhor)
            else:
                break

            # Deteco de loop
            self.entropia.alimentar(palavras[-1])
            if self.entropia.esta_em_loop():
                break

        return ' '.join(palavras)

    #  AUTO-MODIFICAO 

    def auto_diagnosticar(self) -> Dict:
        """Diagnostica o estado do crebro e sugere melhorias."""
        # Gap: conexes entre tpicos
        gaps = []
        topicos_lista = list(self.topicos.keys())
        for i in range(min(len(topicos_lista), 5)):
            for j in range(i + 1, min(len(topicos_lista), 5)):
                a, b = topicos_lista[i], topicos_lista[j]
                ja = MCRByteUtils.jaccard_bytes(
                    self.topicos[a]['texto'], self.topicos[b]['texto'])
                if ja < 0.1:
                    gaps.append(f"{a}{b}: jaccard={ja:.3f}")

        # Hardcodes no cdigo
        hardcodes = self.self_modify.escanear()

        # Estado do coupling
        coupling_fracos = []
        for o in self.coupling.niveis:
            for d in self.coupling.niveis:
                if o != d and self.coupling.peso(o, d) < 0.05:
                    coupling_fracos.append(f"{o}{d}")

        return {
            "topicos": len(self.topicos),
            "conhecimento_byte": self.mk_byte.total,
            "conhecimento_palavra": self.mk_palavra.total,
            "causal_exemplos": len(self.world.historico),
            "causal_entropia": round(self.world.mk_estado.entropia_media(), 3),
            "planos_aprendidos": self.planner.mk_plano.total,
            "gaps": gaps[:3],
            "hardcodes": len(hardcodes),
            "hardcodes_top": hardcodes[:3] if hardcodes else [],
            "coupling_fracos": coupling_fracos[:3],
            "sugestao": (
                f"Alimentar mais dados para cobrir {len(gaps)} gaps. "
                f"{len(hardcodes)} hardcodes detectados no cdigo. "
                f"{len(coupling_fracos)} acoplamentos fracos."
            ),
        }

    def auto_melhorar(self) -> Dict:
        """Auto-melhoria: corrige hardcodes encontrados."""
        hardcodes = self.self_modify.escanear()
        if not hardcodes:
            return {"modificado": False, "motivo": "nenhum hardcode detectado"}

        # Tenta substituir o pior hardcode
        pior = hardcodes[0]
        sucesso = self.self_modify.substituir_hardcode(
            pior["linha"], pior["codigo"], "threshold")

        return {
            "modificado": sucesso,
            "linha": pior["linha"],
            "codigo": pior["codigo"][:50],
            "total_restantes": len(hardcodes) - 1,
        }

    #  RELATRIO COMPLETO 

    def relatorio(self) -> str:
        """Relatrio completo do estado do crebro."""
        w = self.world  # alias
        linhas = []
        linhas.append("=" * 60)
        linhas.append("  CREBRO AGI  RELATRIO COMPLETO")
        linhas.append("=" * 60)
        linhas.append(f"  Ciclos: {self.total_ciclos}")
        linhas.append("")
        linhas.append("   CONHECIMENTO")
        linhas.append(f"    Tpicos: {len(self.topicos)}")
        linhas.append(f"    Bytes: {self.mk_byte.total} transies")
        linhas.append(f"    Palavras: {self.mk_palavra.total} transies")
        linhas.append(f"    Entropia byte: {self.mk_byte.entropia_media():.3f}")
        linhas.append("")
        linhas.append(f"   MCRWorld (Causal)")
        linhas.append(f"    {self.world}")
        linhas.append(f"    Distncia causal mdia: OK{w.mk_estado.entropia_media():.2f}")
        linhas.append("")
        linhas.append(f"   MCRCoupling")
        for o in self.coupling.niveis:
            pesos = [f"{d}:{self.coupling.peso(o,d):.2f}" for d in self.coupling.niveis
                     if o != d and self.coupling.peso(o,d) > 0]
            if pesos:
                linhas.append(f"    {o}  {', '.join(pesos)}")
        linhas.append("")
        linhas.append(f"    MCRPlanner")
        linhas.append(f"    {self.planner}")
        linhas.append("")
        linhas.append(f"   MCRSelfModify")
        linhas.append(f"    {self.self_modify}")
        if self.self_modify.historico:
            linhas.append("    ltimas modificaes:")
            for h in self.self_modify.historico[-3:]:
                linhas.append(f"      L{h['linha']}: {h['antes'][:40]}")
        linhas.append("")
        linhas.append("   DIAGNSTICO")
        diag = self.auto_diagnosticar()
        linhas.append(f"    Gaps: {len(diag['gaps'])}")
        linhas.append(f"    Hardcodes: {diag['hardcodes']}")
        if diag['gaps']:
            for g in diag['gaps']:
                linhas.append(f"      gap: {g}")
        linhas.append(f"    Sugesto: {diag['sugestao']}")
        linhas.append("=" * 60)
        return '\n'.join(linhas)


