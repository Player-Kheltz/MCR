# SEO 7  MCRDecisorUniversal (para auto-modificao)
# 

class MCRDecisorUniversal:
    """Decide parmetros universais baseado no estado do motor."""
    _th = MCRThreshold("decisor_universal")

    @classmethod
    def decidir(cls, motor, contexto: str = "") -> Dict:
        h_byte = motor.mk_byte.entropia_media() if motor.mk_byte.total > 0 else 1
        h_pal = motor.mk_palavra.entropia_media() if motor.mk_palavra.total > 0 else 1
        cls._th.observar(h_byte + h_pal)
        return {
            "passos": max(1, int(cls._th.obter("passos", 6))),
            "max_passos": max(1, int(cls._th.obter("max_passos", 10))),
            "threshold": cls._th.obter("threshold", 0.5),
            "dim": max(4, int(cls._th.obter("dim", 8))),
            "max_candidatos": max(1, int(cls._th.obter("max_candidatos", 5))),
            "conf_min": cls._th.obter("conf_min", 0.15),
        }


