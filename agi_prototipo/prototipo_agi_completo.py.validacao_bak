class MotorFisica:
    """Motor de fsica simples que executa aes no mundo."""
    @staticmethod
    def executar(estado: EstadoMundo, acao: str) -> EstadoMundo:
        """Retorna NOVO estado aps executar a ao."""
        novo = estado.clone()
        heroi = novo.get("heroi")
        if not heroi: return novo

        x, y = heroi.props.get("x", 0), heroi.props.get("y", 0)

        if acao == "andar_cima" and y > 0:
            novo.entidades["heroi"].props["y"] = y - 1
        elif acao == "andar_baixo" and y < novo.grid_h - 1:
            novo.entidades["heroi"].props["y"] = y + 1
        elif acao == "andar_esq" and x > 0:
            novo.entidades["heroi"].props["x"] = x - 1
        elif acao == "andar_dir" and x < novo.grid_w - 1:
            novo.entidades["heroi"].props["x"] = x + 1
        elif acao == "empurrar":
            # Empurra entidade adjacente na direo do heroi
            target = MotorFisica._entidade_adjacente(novo, x, y)
            if target:
                dx = target.props.get("x", 0) - x
                dy = target.props.get("y", 0) - y
                nx, ny = target.props.get("x", 0) + dx, target.props.get("y", 0) + dy
                if 0 <= nx < novo.grid_w and 0 <= ny < novo.grid_h:
                    if (nx, ny) not in novo.obstaculos:
                        novo.entidades[target.nome].props["x"] = nx
                        novo.entidades[target.nome].props["y"] = ny
        elif acao == "abrir":
            target = MotorFisica._entidade_adjacente(novo, x, y)
            if target and "aberto" in target.props:
                novo.entidades[target.nome].props["aberto"] = True
        elif acao == "atacar":
            target = MotorFisica._entidade_adjacente(novo, x, y)
            if target and "hp" in target.props:
                novo.entidades[target.nome].props["hp"] = target.props["hp"] - 3
                if novo.entidades[target.nome].props["hp"] <= 0:
                    novo.remover(target.nome)

        return novo

    @staticmethod
    def _entidade_adjacente(estado: EstadoMundo, x: int, y: int) -> Optional[Entidade]:
        """Encontra entidade adjacente ao heroi.
        Prefere entidades atacaveis (com hp) ou interagiveis."""
        candidatos = []
        for nome, ent in estado.entidades.items():
            if nome == "heroi": continue
            ex, ey = ent.props.get("x", -1), ent.props.get("y", -1)
            if abs(ex - x) + abs(ey - y) == 1:
                candidatos.append(ent)
        if not candidatos: return None
        # Prefere entidade com hp (atacavel), depois interagivel
        atacaveis = [e for e in candidatos if "hp" in e.props]
        if atacaveis: return atacaveis[0]
        interagiveis = [e for e in candidatos if "aberto" in e.props]
        if interagiveis: return interagiveis[0]
        return candidatos[0]


class MCRWorld:
    """Modelo de mundo causal: aprende transies de estado.

    Armazena a memria causal do mundo:
      mk_estado:  fingerprint_atual  fingerprint_seguinte
      mk_acao:    fingerprint_atual + ao  fingerprint_seguinte
      mk_causal:  delta(fingerprints)  ao que produz este delta
      mk_plano:   fingerprint_objetivo  sequncia de aes bem-sucedida
    """
    def __init__(self):
        self.mk_estado = MCR("world_estado")
        self.mk_acao = MCR("world_acao")
        self.mk_causal = MCR("world_causal")
        self.mk_plano = MCR("world_plano")
        self.historico: List[Dict] = []
        self.threshold = MCRThreshold("world")
        self.fisica = MotorFisica()
        self.entropia = MCREntropia("world")
        self.dim_fp = 8

    def aprender(self, antes: EstadoMundo, acao: str, depois: EstadoMundo):
        """Aprende que (antes + ao  depois)."""
        fp_antes = antes.fingerprint(self.dim_fp)
        fp_depois = depois.fingerprint(self.dim_fp)
        antes_str = str(fp_antes)
        depois_str = str(fp_depois)

        # Markov de transio de estado
        self.mk_estado.aprender(antes_str, depois_str)

        # Markov de ao (estado + ao  prximo estado)
        chave_acao = f"{antes_str}:{acao}"
        self.mk_acao.aprender(chave_acao, depois_str)

        # Markov causal (delta  ao que produz este delta)
        delta = tuple(round(d, 3) for d in MCRByteUtils.delta_fingerprint(
            antes.serializar(), depois.serializar(), self.dim_fp))
        self.mk_causal.aprender(str(delta), acao)

        self.historico.append({
            "antes": antes.serializar()[:40],
            "acao": acao,
            "depois": depois.serializar()[:40],
            "delta": delta[:3],
        })
        self.threshold.observar(
            MCRByteUtils.jaccard_bytes(antes.serializar(), depois.serializar()))

    def simular(self, estado: EstadoMundo, acao: str) -> Optional[EstadoMundo]:
        """Simula (estado + ao) usando conhecimento aprendido.
        Fallback: motor de fsica real."""
        fp_atual = estado.fingerprint(self.dim_fp)
        chave_acao = f"{str(fp_atual)}:{acao}"

        prox_fp_str, conf = self.mk_acao.predizer(chave_acao)
        if prox_fp_str and conf > 0.15:
            # Tenta reconstruir estado do fingerprint
            return self._reconstruir_estado(prox_fp_str, estado)

        # Fallback: tenta transio de estado pura
        prox_fp_str2, conf2 = self.mk_estado.predizer(str(fp_atual))
        if prox_fp_str2 and conf2 > 0.3:
            return self._reconstruir_estado(prox_fp_str2, estado)

        # ltimo fallback: motor de fsica
        return self.fisica.executar(estado, acao)

    def _reconstruir_estado(self, fp_str: str, estado_ref: EstadoMundo) -> EstadoMundo:
        """Reconstri estado a partir de fingerprint e referncia."""
        # Busca no histrico o estado mais prximo
        melhor_estado = None
        melhor_sim = 0.0
        for h in self.historico[-50:]:
            e = EstadoMundo()
            try:
                for part in h["depois"].split("|"):
                    if ":" in part:
                        nome, resto = part.split(":", 1)
                        if ":" in resto:
                            tipo, props_str = resto.split(":", 1)
                            props = {}
                            for p in props_str.split(";"):
                                if "=" in p:
                                    k, v = p.split("=", 1)
                                    try: v = int(v)
                                    except: pass
                                    props[k] = v
                            e.adicionar(Entidade(nome, tipo, props))
            except: continue
            fp_e = str(e.fingerprint(self.dim_fp))
            sim = MCRByteUtils.similaridade_cosseno(
                [float(x) for x in fp_str.strip("[]").split(",") if x.strip()],
                [float(x) for x in fp_e.strip("[]").split(",") if x.strip()],
            ) if fp_e else 0
            if sim > melhor_sim:
                melhor_sim = sim
                melhor_estado = e

        return melhor_estado or estado_ref.clone()

    def predizer_acao(self, antes: EstadoMundo, depois: EstadoMundo) -> Optional[str]:
        """Descobre qual ao transforma 'antes' em 'depois'.
        Isto  DESCOBERTA CAUSAL: o delta do fingerprint revela a ao."""
        delta = tuple(round(d, 3) for d in MCRByteUtils.delta_fingerprint(
            antes.serializar(), depois.serializar(), self.dim_fp))
        acao, conf = self.mk_causal.predizer(str(delta))
        if acao and conf > 0.1:
            return acao
        return None

    def contrafactual(self, estado: EstadoMundo, acao: str,
                      var_nome: str, var_valor: Any) -> str:
        """'E se {varivel} fosse {valor}?'  raciocnio contrafactual."""
        # Estado normal
        resultado_normal = self.simular(estado, acao)
        fp_normal = resultado_normal.fingerprint(self.dim_fp) if resultado_normal else []

        # Estado alternativo (modifica varivel)
        estado_alt = estado.clone()
        for ent in estado_alt.entidades.values():
            if var_nome in ent.props:
                ent.props[var_nome] = var_valor

        resultado_alt = self.simular(estado_alt, acao)
        fp_alt = resultado_alt.fingerprint(self.dim_fp) if resultado_alt else []

        if not fp_normal or not fp_alt:
            return f"No h dados para contrafactual de '{var_nome}={var_valor}'."

        delta = MCRByteUtils.delta_fingerprint(
            resultado_normal.serializar() if resultado_normal else "",
            resultado_alt.serializar() if resultado_alt else "",
            self.dim_fp
        )
        mag = math.sqrt(sum(d*d for d in delta))
        return (
            f"Contrafactual: se '{var_nome}' fosse '{var_valor}', "
            f"o resultado mudaria em {mag:.2f} unidades de fingerprint. "
            f"Delta: {[round(d, 2) for d in delta[:4]]}"
        )

    def distancia(self, a: EstadoMundo, b: EstadoMundo) -> float:
        """Distncia causal entre dois estados."""
        fp_a = a.fingerprint(self.dim_fp)
        fp_b = b.fingerprint(self.dim_fp)
        delta = [fp_b[i] - fp_a[i] for i in range(self.dim_fp)]
        return math.sqrt(sum(d*d for d in delta))

    def stats(self) -> Dict:
        return {
            "transicoes_estado": self.mk_estado.total,
            "transicoes_acao": self.mk_acao.total,
            "transicoes_causais": self.mk_causal.total,
            "exemplos_aprendidos": len(self.historico),
            "entropia_estado": round(self.mk_estado.entropia_media(), 3),
        }

    def __repr__(self):
        s = self.stats()
        return (f"MCRWorld: {s['exemplos_aprendidos']} exemplos, "
                f"{s['transicoes_estado']} transies, "
                f"{s['transicoes_causais']} causais, H={s['entropia_estado']}")


