class Entidade:
    """Uma entidade no mundo: tem posio, propriedades, estado."""
    def __init__(self, nome: str, tipo: str = "objeto", props: Dict = None):
        self.nome = nome
        self.tipo = tipo
        self.props = props or {}

    def __repr__(self):
        return f"{self.nome}({self.props})"

    def clone(self) -> 'Entidade':
        return Entidade(self.nome, self.tipo, dict(self.props))


class EstadoMundo:
    """Estado completo do mundo em um instante."""
    def __init__(self):
        self.entidades: Dict[str, Entidade] = {}
        self.grid_w: int = 5
        self.grid_h: int = 5
        self.obstaculos: Set[Tuple[int, int]] = set()

    def adicionar(self, ent: Entidade):
        self.entidades[ent.nome] = ent

    def remover(self, nome: str):
        self.entidades.pop(nome, None)

    def get(self, nome: str) -> Optional[Entidade]:
        return self.entidades.get(nome)

    def serializar(self) -> str:
        """Converte estado completo em string deterministicamente."""
        partes = []
        for nome in sorted(self.entidades.keys()):
            e = self.entidades[nome]
            props_ordenadas = sorted(e.props.items())
            partes.append(f"{nome}:{e.tipo}:" + ";".join(f"{k}={v}" for k, v in props_ordenadas))
        # obstculos
        if self.obstaculos:
            obs = sorted(self.obstaculos)
            partes.append("obs:" + ";".join(f"{x},{y}" for x, y in obs))
        return "|".join(partes)

    def fingerprint(self, dim: int = 8) -> List[float]:
        return MCRByteUtils.fingerprint(self.serializar(), dim)

    def clone(self) -> 'EstadoMundo':
        e = EstadoMundo()
        e.entidades = {n: ent.clone() for n, ent in self.entidades.items()}
        e.grid_w, e.grid_h = self.grid_w, self.grid_h
        e.obstaculos = set(self.obstaculos)
        return e

    @staticmethod
    def criar_simples() -> 'EstadoMundo':
        """Cria um mundo simples para demonstrao."""
        e = EstadoMundo()
        e.adicionar(Entidade("heroi", "jogador", {"x": 0, "y": 0, "hp": 10}))
        e.adicionar(Entidade("pedra", "objeto", {"x": 2, "y": 2, "gravidade": True}))
        e.adicionar(Entidade("bau", "objeto", {"x": 4, "y": 4, "aberto": False}))
        e.adicionar(Entidade("monstro", "inimigo", {"x": 3, "y": 1, "hp": 5}))
        e.obstaculos = {(2, 3)}
        return e


